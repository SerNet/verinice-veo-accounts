{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergeAll",
    ":automergePr"
  ],
  "assignAutomerge": true,
  "reviewers": [
    "JJ"
  ],
  "packageRules": [
    {
      "groupName": "Kotlin",
      "matchPackageNames": [
        "/^org.jetbrains.kotlin/"
      ]
    },
    {
      "groupName": "Keycloak Client",
      "matchPackageNames": [
        "/^org.keycloak:/"
      ]
    },
    {
      "groupName": "Kotest",
      "matchPackageNames": [
        "/^io.kotest:/"
      ]
    },
    {
      "groupName": "Spotless",
      "postUpgradeTasks": {
        "commands": [
          "./gradlew spotlessApply"
        ],
        "fileFilters": [
          "**/*"
        ]
      },
      "matchPackageNames": [
        "/^com.diffplug.spotless/"
      ]
    },
    {
      "matchPackageNames": [
        "eclipse-temurin"
      ],
      "allowedVersions": "25-jdk"
    }
  ]
}
